ZSH_ALIAS_DIR=$HOME/.config/shell

# Java
[ -f $ZSH_ALIAS_DIR/java.alias ] && source $ZSH_ALIAS_DIR/java.alias

# brew
[ -f $ZSH_ALIAS_DIR/brew.alias ] && source $ZSH_ALIAS_DIR/brew.alias

# gnutools
[ -f $ZSH_ALIAS_DIR/gnutools.alias ] && source $ZSH_ALIAS_DIR/gnutools.alias

# homelab
[ -f $ZSH_ALIAS_DIR/homelab.alias.local ] && source $ZSH_ALIAS_DIR/homelab.alias.local

# DevOpsTools
[ -f $ZSH_ALIAS_DIR/devopstools.alias ] && source $ZSH_ALIAS_DIR/devopstools.alias

# ColorLS
[ -f $ZSH_ALIAS_DIR/colorls.alias ] && source $ZSH_ALIAS_DIR/colorls.alias

alias dotfiles="/usr/bin/git --git-dir=${HOME}/.dotfiles/ --work-tree=${HOME}"

